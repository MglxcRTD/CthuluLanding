---

---

<section
  class="fourth-section relative flex flex-col py-16 sm:py-24 md:py-32 xl:py-44 px-4 sm:px-6 md:px-16 bg-transparent"
>
  <!-- Fondo atmosférico -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div
      class="absolute top-[0%] left-[20%] w-[60%] h-[40%] bg-[#02735e]/25 blur-[180px] rounded-full animate-breathe-4"
    >
    </div>
    <div
      class="absolute bottom-[5%] left-[-5%] w-[40%] h-[40%] bg-[#d91414]/15 blur-[120px] rounded-full animate-breathe-4b"
    >
    </div>
    <div
      class="absolute bottom-[0%] right-[-5%] w-[45%] h-[45%] bg-[#84d9d0]/15 blur-[140px] rounded-full animate-breathe-4c"
    >
    </div>
    <!-- Grid de puntos tipo BioShock -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle, rgba(132,217,208,0.8) 1px, transparent 1px); background-size: 40px 40px;"
    >
    </div>
  </div>

  <div class="max-w-7xl mx-auto relative z-10 space-y-12 sm:space-y-16 md:space-y-20 xl:space-y-28">
    <!-- Título centro arriba -->
    <div class="text-center flex flex-col items-center gap-6">
      <div class="flex items-center gap-4 opacity-60">
        <div
          class="w-20 h-[1px] bg-gradient-to-r from-transparent to-[#84d9d0]/50"
        >
        </div>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path
            d="M8 0L9.5 6.5L16 8L9.5 9.5L8 16L6.5 9.5L0 8L6.5 6.5Z"
            fill="rgba(132,217,208,0.5)"></path>
        </svg>
        <div
          class="w-20 h-[1px] bg-gradient-to-l from-transparent to-[#84d9d0]/50"
        >
        </div>
      </div>


      <h2
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-black uppercase leading-[0.88] text-white section-title-4 text-center"
      >
        Desafía los límites <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[#84d9d0] via-[#02735e] to-[#d91414]"
        >
          de tu mente
        </span>
      </h2>

      <p
        class="text-[#84d9d0]/60 text-base sm:text-lg md:text-xl font-light max-w-2xl leading-relaxed text-center"
      >
        Cada decisión te acerca o te aleja del umbral de la cordura. El horror
        no se derrota: se sobrevive.
      </p>

      <div
        class="h-[1px] w-32 bg-gradient-to-r from-transparent via-[#84d9d0]/40 to-transparent"
      >
      </div>
    </div>

    <!-- Grid de tarjetas: imagen + texto -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Tarjeta 1 -->
      <div class="group relative flex flex-col">
        <!-- Halo -->
        <div
          class="absolute -inset-4 bg-[#02735e]/5 blur-[50px] rounded-2xl opacity-0 group-hover:opacity-100 transition-all duration-1000"
        >
        </div>

        <div class="relative overflow-hidden flex-shrink-0">
          <div
            class="absolute top-0 left-0 w-8 h-8 border-t border-l border-[#84d9d0]/40 z-20"
          >
          </div>
          <div
            class="absolute top-0 right-0 w-8 h-8 border-t border-r border-[#84d9d0]/40 z-20"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 w-8 h-8 border-b border-l border-[#84d9d0]/40 z-20"
          >
          </div>
          <div
            class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-[#84d9d0]/40 z-20"
          >
          </div>
          <div
            class="absolute inset-0 bg-gradient-to-b from-transparent to-[#000d0c]/60 z-10 pointer-events-none"
          >
          </div>
          <div
            class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.06)_50%)] bg-[length:100%_3px] z-10 opacity-40 pointer-events-none"
          >
          </div>
          <img
            src="/CthulhuLanding/Screenshot_4 (1).jpg"
            alt="Exploración"
            class="w-full h-56 md:h-64 object-cover transition-all duration-[1200ms] group-hover:scale-105 group-hover:brightness-110"
          />
        </div>

        <div class="relative z-10 pt-6 space-y-3 flex-1">
          <div class="flex items-center gap-3">
            <div class="w-4 h-[1px] bg-[#84d9d0]/50"></div>
       
            
          </div>
          <h3
            class="text-xl sm:text-2xl md:text-3xl font-black uppercase text-white card-title"
          >
            Exploración<br />
            <span class="text-[#84d9d0]/80">Subterránea</span>
          </h3>
          <p class="text-[#84d9d0]/55 text-base font-light leading-relaxed">
           Sumergirse en la oscuridad con Key, el compañero IA,
             <span class="text-[#84d9d0]/80">implica seguir pistas</span>, reunir indicios
dispersos y agudizar las dotes de detective para resolver enigmas complejos e inmersivos.
          </p>
        </div>
      </div>

      <!-- Tarjeta 2 -->
      <div class="group relative flex flex-col">
        <div
          class="absolute -inset-4 bg-[#d91414]/5 blur-[50px] rounded-2xl opacity-0 group-hover:opacity-100 transition-all duration-1000"
        >
        </div>

        <div class="relative overflow-hidden flex-shrink-0">
          <div
            class="absolute top-0 left-0 w-8 h-8 border-t border-l border-[#d91414]/40 z-20"
          >
          </div>
          <div
            class="absolute top-0 right-0 w-8 h-8 border-t border-r border-[#d91414]/40 z-20"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 w-8 h-8 border-b border-l border-[#d91414]/40 z-20"
          >
          </div>
          <div
            class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-[#d91414]/40 z-20"
          >
          </div>
          <div
            class="absolute inset-0 bg-gradient-to-b from-transparent to-[#000d0c]/60 z-10 pointer-events-none"
          >
          </div>
          <div
            class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.06)_50%)] bg-[length:100%_3px] z-10 opacity-40 pointer-events-none"
          >
          </div>
          <img
            src="/CthulhuLanding/Screenshot_2.jpg"
            alt="Sanidad"
            class="w-full h-56 md:h-64 object-cover transition-all duration-[1200ms] group-hover:scale-105 group-hover:brightness-110"
          />
        </div>

        <div class="relative z-10 pt-6 space-y-3 flex-1">
          <div class="flex items-center gap-3">
            <div class="w-4 h-[1px] bg-[#d91414]/50"></div>
          </div>
          <h3
            class="text-xl sm:text-2xl md:text-3xl font-black uppercase text-white card-title"
          >
            Descubre el<br />
            <span class="text-[#d91414]/80">Camino</span>
          </h3>
          <p class="text-[#84d9d0]/55 text-base font-light leading-relaxed">
            A lo
largo de la investigación, será necesario descubrir verdades ocultas y mirar más allá de las
apariencias para elegir el camino en la resolución del caso, ya que cada misterio ofrece
diferentes rutas y <span
              class="text-[#d91414]/70">pasajes secretos</span
            > que están esperando ser descubiertos.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Botón Compra Ya -->
  <div class="relative z-10 flex justify-center pt-16 sm:pt-20 md:pt-28">
    <a href="#comprar" class="buy-btn group relative">
      <div
        class="absolute -inset-[1px] bg-gradient-to-r from-[#84d9d0]/0 via-[#84d9d0]/40 to-[#84d9d0]/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      >
      </div>
      <div
        class="relative border border-[#84d9d0]/30 bg-[#000d0c]/80 backdrop-blur-sm px-12 py-4 group-hover:border-[#84d9d0]/60 transition-all duration-500 overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-[#84d9d0]/0 group-hover:bg-[#84d9d0]/5 transition-all duration-500"
        >
        </div>
        <div
          class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-[linear-gradient(transparent_50%,rgba(132,217,208,0.05)_50%)] bg-[length:100%_3px] animate-interference"
        >
        </div>
        <span
          class="relative z-10 text-[#84d9d0]/60 group-hover:text-[#84d9d0] text-xs uppercase tracking-[0.5em] font-serif transition-all duration-300"
        >
          ◈ Compra Ya ◈
        </span>
      </div>
    </a>
  </div>
</section>

<style>
  .section-title-4,
  .card-title {
    font-family: "Georgia", "Times New Roman", serif;
  }

  @keyframes breathe-4 {
    0%,
    100% {
      opacity: 0.1;
      transform: scale(1);
    }
    50% {
      opacity: 0.2;
      transform: scale(1.07);
    }
  }
  .animate-breathe-4 {
    animation: breathe-4 16s ease-in-out infinite;
  }
  .animate-breathe-4b {
    animation: breathe-4 20s ease-in-out infinite 4s;
  }
  .animate-breathe-4c {
    animation: breathe-4 13s ease-in-out infinite 7s;
  }

  @keyframes interference {
    0% {
      background-position: 0 0;
    }
    100% {
      background-position: 0 100%;
    }
  }
  .animate-interference {
    animation: interference 0.3s infinite linear;
  }
</style>
