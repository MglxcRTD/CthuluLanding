---
---
<section
  class="third-section relative flex flex-col py-16 sm:py-24 md:py-44 px-4 sm:px-6 md:px-16 bg-transparent"
>
  <!-- Fondo con efecto de profundidad distinto -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-[-10%] right-[-10%] w-[65%] h-[65%] bg-[#d91414]/15 blur-[160px] rounded-full animate-pulse-deep"></div>
    <div class="absolute bottom-[-15%] left-[-5%] w-[55%] h-[55%] bg-[#02735e]/25 blur-[140px] rounded-full animate-pulse-deep-2"></div>
    <div class="absolute top-[50%] left-[45%] w-[20%] h-[20%] bg-[#84d9d0]/15 blur-[80px] rounded-full"></div>
    <!-- Patrón de ondas sonar -->
    <div class="sonar-rings absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  </div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 sm:gap-16 lg:gap-28 items-center relative z-10">

    <!-- Imagen izquierda -->
    <div class="relative group order-1">
      <div class="absolute -inset-8 bg-[#d91414]/8 blur-[70px] rounded-full opacity-50 group-hover:opacity-90 group-hover:bg-[#d91414]/12 transition-all duration-1000"></div>
      
      <div class="relative overflow-hidden">
        <!-- Número de archivo estilo BioShock arriba -->
        <div class="absolute top-0 left-0 right-0 bg-gradient-to-b from-[#000d0c]/80 to-transparent z-20 px-4 py-3">
          <span class="text-[#84d9d0]/40 text-[9px] font-mono uppercase tracking-[0.5em]">
            ◈ SECTOR PROFUNDO · ACCESO RESTRINGIDO ◈
          </span>
        </div>
        <!-- Esquinas -->
        <div class="absolute top-0 left-0 w-10 h-10 border-t border-l border-[#d91414]/40 z-20"></div>
        <div class="absolute top-0 right-0 w-10 h-10 border-t border-r border-[#d91414]/40 z-20"></div>
        <div class="absolute bottom-0 left-0 w-10 h-10 border-b border-l border-[#d91414]/40 z-20"></div>
        <div class="absolute bottom-0 right-0 w-10 h-10 border-b border-r border-[#d91414]/40 z-20"></div>
        <!-- Overlay -->
        <div class="absolute inset-0 bg-gradient-to-br from-transparent to-[#000d0c]/50 z-10 pointer-events-none"></div>
        <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.05)_50%)] bg-[length:100%_3px] z-10 opacity-40 pointer-events-none"></div>

        <img
          src="/CthulhuLanding/Screenshot_3 (1).jpg"
          alt="Las profundidades"
          class="w-full h-auto object-cover transition-all duration-[1500ms] group-hover:scale-105 group-hover:brightness-110 relative z-0"
        />

        <!-- Barra inferior con dato -->
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-[#000d0c]/90 to-transparent z-20 px-4 pb-4 pt-8">
          <div class="flex items-center justify-between">
            <span class="text-[#84d9d0]/50 text-[9px] font-mono uppercase tracking-[0.4em]">LATITUD: 47°9'S</span>
            <span class="text-[#84d9d0]/50 text-[9px] font-mono uppercase tracking-[0.4em]">LONGITUD: 126°43'W</span>
          </div>
        </div>
      </div>

      <!-- Elemento decorativo vertical izquierda -->
      <div class="absolute -left-6 top-0 bottom-0 flex flex-col items-center gap-2 opacity-30">
        <div class="w-[1px] flex-1 bg-gradient-to-b from-transparent via-[#84d9d0] to-transparent"></div>
      </div>
    </div>

    <!-- Texto derecha -->
    <div class="flex flex-col space-y-8 order-2">

      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black uppercase leading-[0.88] text-white section-title-3">
        Revela lo<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-br from-[#d91414] via-[#84d9d0] to-[#02735e]">
          innombrable
        </span>
      </h2>

      <div class="flex items-center gap-3">
        <div class="w-12 h-[1px] bg-gradient-to-r from-[#d91414]/60 to-transparent"></div>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
          <path d="M5 0L6 4L10 5L6 6L5 10L4 6L0 5L4 4Z" fill="rgba(217,20,20,0.5)"/>
        </svg>
        <div class="w-full h-[1px] bg-gradient-to-r from-[#d91414]/20 to-transparent"></div>
      </div>

      <p class="text-[#84d9d0]/70 text-base sm:text-lg md:text-xl font-light leading-relaxed tracking-wide">
        A lo largo de la aventura, el jugador se enfrentará a pesadillas y abominaciones cósmicas que
pondrán a prueba <span class="text-[#84d9d0] font-medium">los límites de su cordura</span>. Se adentrará en una reinterpretación futurista de
los mitos de Lovecraft y descubrirá la legendaria ciudad sumergida de R’lyeh.
      </p>

      <p class="text-[#84d9d0]/50 text-sm sm:text-base md:text-lg font-light leading-relaxed">
        Pero cuanto más
profundo descienda, más sucumbirá su mente <span class="text-[#d91414]/80 italic">a la implacable influencia de Cthulhu.</span>
      </p>

      <!-- Cita del libro -->
      <div class="relative pl-6 border-l-2 border-[#d91414]/30 mt-4">
        <div class="absolute top-0 left-0 bottom-0 w-[2px] bg-gradient-to-b from-[#d91414]/60 via-[#d91414]/20 to-transparent"></div>
  
      </div>
    </div>
  </div>

  <!-- Botón Compra Ya -->
  <div class="relative z-10 flex justify-center pt-16 sm:pt-20 md:pt-28">
    <a href="#comprar" class="buy-btn group relative">
      <div class="absolute -inset-[1px] bg-gradient-to-r from-[#d91414]/0 via-[#d91414]/40 to-[#d91414]/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="relative border border-[#84d9d0]/30 bg-[#000d0c]/80 backdrop-blur-sm px-12 py-4 group-hover:border-[#d91414]/50 transition-all duration-500 overflow-hidden">
        <div class="absolute inset-0 bg-[#d91414]/0 group-hover:bg-[#d91414]/5 transition-all duration-500"></div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-[linear-gradient(transparent_50%,rgba(217,20,20,0.04)_50%)] bg-[length:100%_3px] animate-interference"></div>
        <span class="relative z-10 text-[#84d9d0]/60 group-hover:text-[#d91414]/80 text-xs uppercase tracking-[0.5em] font-serif transition-all duration-300">
          ◈ Compra Ya ◈
        </span>
      </div>
    </a>
  </div>
</section>

<style>
  .section-title-3 {
    font-family: 'Georgia', 'Times New Roman', serif;
    text-shadow: 0 0 80px rgba(217, 20, 20, 0.08);
  }

  @keyframes pulse-deep {
    0%, 100% { opacity: 0.08; transform: scale(1); }
    50% { opacity: 0.18; transform: scale(1.1); }
  }
  .animate-pulse-deep { animation: pulse-deep 14s ease-in-out infinite; }
  .animate-pulse-deep-2 { animation: pulse-deep 18s ease-in-out infinite 5s; }

  /* Anillos de sonar decorativos */
  .sonar-rings::before,
  .sonar-rings::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(132, 217, 208, 0.04);
    transform: translate(-50%, -50%);
    animation: sonar-expand 8s ease-out infinite;
  }
  .sonar-rings::before { width: 400px; height: 400px; animation-delay: 0s; }
  .sonar-rings::after { width: 600px; height: 600px; animation-delay: 4s; }

  @keyframes sonar-expand {
    0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0.3; }
    100% { transform: translate(-50%, -50%) scale(1.5); opacity: 0; }
  }

  @keyframes interference {
    0% { background-position: 0 0; }
    100% { background-position: 0 100%; }
  }
  .animate-interference { animation: interference 0.3s infinite linear; }
</style>