                target="_blank"
                rel="noopener"
                class="store-link group/store relative border border-[#84d9d0]/15 bg-[#84d9d0]/3 hover:bg-[#84d9d0]/8 hover:border-[#84d9d0]/30 transition-all duration-300 p-3 flex items-center justify-center overflow-hidden"
              >
                <div class="absolute inset-0 opacity-0 group-hover/store:opacity-100 bg-[linear-gradient(transparent_50%,rgba(132,217,208,0.04)_50%)] bg-[length:100%_3px] animate-interference pointer-events-none"></div>
                <img
                  src="/CthulhuLanding/mediamarkt.png"
                  alt="MediaMarkt"
                  class="h-6 w-auto object-contain brightness-[2] contrast-[1.1] opacity-60 group-hover/store:opacity-100 transition-opacity duration-300"
                />
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Plataforma 2 - derecha (Nintendo Switch 2, con links) -->
      <div class="platform-card group relative flex flex-col">
        <div class="absolute -inset-6 bg-[#84d9d0]/6 blur-[60px] opacity-0 group-hover:opacity-100 transition-all duration-1000 rounded-2xl"></div>
        
        <!-- Marco y carátula -->
        <div class="relative overflow-hidden mb-6 flex-shrink-0">
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#000d0c]/50 z-10 pointer-events-none"></div>
          <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.05)_50%)] bg-[length:100%_3px] z-10 opacity-40 pointer-events-none"></div>
          <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-[#84d9d0]/50 z-20"></div>
          <div class="absolute top-0 right-0 w-8 h-8 border-t border-r border-[#84d9d0]/50 z-20"></div>
          <div class="absolute bottom-0 left-0 w-8 h-8 border-b border-l border-[#84d9d0]/50 z-20"></div>
          <div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-[#84d9d0]/50 z-20"></div>
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 shadow-[inset_0_0_60px_rgba(132,217,208,0.10)] transition-all duration-1000 z-10 pointer-events-none"></div>

          <img
            src="/CthulhuLanding/XBOX_Cthulhu_2D_PEGI.png"
            alt="Xbox"
            class="w-full h-auto object-contain transition-all duration-[1200ms] group-hover:scale-103 bg-[#070f0e]"
