                target="_blank"
                rel="noopener"
                class="store-link group/store relative border border-[#84d9d0]/15 bg-[#84d9d0]/3 hover:bg-[#84d9d0]/8 hover:border-[#84d9d0]/30 transition-all duration-300 p-3 flex items-center justify-center overflow-hidden"
              >
                <div class="absolute inset-0 opacity-0 group-hover/store:opacity-100 bg-[linear-gradient(transparent_50%,rgba(132,217,208,0.04)_50%)] bg-[length:100%_3px] animate-interference pointer-events-none"></div>
                <img
                  src="/CthulhuLanding/Logo_GAME_Store_Iberia.png"
                  alt="GAME"
                  class="h-6 w-auto object-contain brightness-[2] contrast-[1.1] opacity-60 group-hover/store:opacity-100 transition-opacity duration-300"
                />
              </a>
              <a
                href="https://www.fnac.es/CthulhuLanding-The-Cosmic-Abyss-PS5-Videojuego-PS5/a12902635"
                target="_blank"
                rel="noopener"
                class="store-link group/store relative border border-[#84d9d0]/15 bg-[#84d9d0]/3 hover:bg-[#84d9d0]/8 hover:border-[#84d9d0]/30 transition-all duration-300 p-3 flex items-center justify-center overflow-hidden"
