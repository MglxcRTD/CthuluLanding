<style>
  .buying-title {
    font-family: 'Georgia', 'Times New Roman', serif;
    text-shadow: 0 0 100px rgba(132, 217, 208, 0.15);
  }

  @keyframes buying-glow {
    0%, 100% { opacity: 0.12; transform: scale(1); }
    50% { opacity: 0.22; transform: scale(1.08); }
  }
  .animate-buying-glow-a { animation: buying-glow 16s ease-in-out infinite; }
  .animate-buying-glow-b { animation: buying-glow 20s ease-in-out infinite 5s; }

  @keyframes shimmer-buy {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  .animate-shimmer-buy {
    background-size: 200% auto;
    animation: shimmer-buy 7s linear infinite;
  }

  @keyframes interference {
    0% { background-position: 0 0; }
    100% { background-position: 0 100%; }
  }
  .animate-interference { animation: interference 0.3s infinite linear; }
</style>