---
---
<section
  id="comprar"
  class="buying-section relative flex flex-col py-16 sm:py-24 md:py-44 px-4 sm:px-6 md:px-16 -mt-16 sm:-mt-24 md:-mt-32 z-20"
>
  <!-- Contenedor del Fondo con Imagen y Degradado -->
  <div class="absolute inset-0 z-0">
    <!-- Imagen de fondo con efecto parallax -->
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="
        background-image: url('/CthulhuLanding/Screenshot_4.jpg');
        background-attachment: fixed;
        background-position: center top;
      "
    >
    </div>
    <!-- Degradados de transición suaves para fundir cortes duros arriba y abajo -->
    <div class="absolute inset-0 bg-abyss-black/20 z-0"></div> <!-- Oscurece ligeramente la imagen para mejorar legibilidad -->
  </div>

  <!-- Contenido de la sección -->
  <div class="max-w-7xl mx-auto relative z-30">

    <!-- Texto arriba centro -->
    <div class="text-center flex flex-col items-center gap-6 pb-16 md:pb-24">
      <!-- Ornamento superior -->
      <div class="flex items-center gap-4">
        <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#84d9d0]/50"></div>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 0L11.8 8.2L20 10L11.8 11.8L10 20L8.2 11.8L0 10L8.2 8.2Z" fill="rgba(132,217,208,0.4)"/>
        </svg>
        <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#84d9d0]/50"></div>
      </div>

      <div class="flex items-center gap-3">
      </div>

      <h2 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black uppercase leading-[0.85] text-white buying-title">
        Compra<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#84d9d0] via-[#02735e] to-[#84d9d0] animate-shimmer-buy">
          Ya
        </span>
      </h2>


      <div class="h-[1px] w-24 bg-gradient-to-r from-transparent via-[#84d9d0]/30 to-transparent"></div>
    </div>

    <!-- Tarjetas de plataformas: izquierda y derecha con espacio central -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 max-w-4xl mx-auto">

      <!-- Plataforma 1 - izquierda -->
      <div class="platform-card group relative flex flex-col">
        <!-- Halo hover -->
        <div class="absolute -inset-6 bg-[#84d9d0]/5 blur-[60px] opacity-0 group-hover:opacity-100 transition-all duration-1000 rounded-2xl"></div>
        
        <!-- Marco y carátula -->
        <div class="relative overflow-hidden mb-6 flex-shrink-0">
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#000d0c]/50 z-10 pointer-events-none"></div>
          <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.05)_50%)] bg-[length:100%_3px] z-10 opacity-40 pointer-events-none"></div>
          <!-- Esquinas -->
          <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-[#84d9d0]/40 z-20"></div>
          <div class="absolute top-0 right-0 w-8 h-8 border-t border-r border-[#84d9d0]/40 z-20"></div>
          <div class="absolute bottom-0 left-0 w-8 h-8 border-b border-l border-[#84d9d0]/40 z-20"></div>
          <div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-[#84d9d0]/40 z-20"></div>
          <!-- Glow hover -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 shadow-[inset_0_0_60px_rgba(132,217,208,0.08)] transition-all duration-1000 z-10 pointer-events-none"></div>

          <img
            src="/CthulhuLanding/PS5_Cthulhu_2D_PEGI.png"
            alt="PlayStation 5"
            class="w-full h-auto object-contain transition-all duration-[1200ms] group-hover:scale-103 bg-[#070f0e]"
          />

          <!-- Badge plataforma -->
          <div class="absolute top-3 left-3 z-20 bg-[#000d0c]/80 border border-[#84d9d0]/20 px-3 py-1">
            <span class="text-[#84d9d0]/60 text-[9px] font-mono uppercase tracking-[0.4em]">PS5</span>
          </div>
          <!-- Badge disponible -->
          <div class="absolute top-3 right-3 z-20 bg-[#02735e]/30 border border-[#84d9d0]/30 px-3 py-1">
            <div class="flex items-center gap-1.5">
              <div class="w-1 h-1 rounded-full bg-[#84d9d0] animate-pulse"></div>
              <span class="text-[#84d9d0] text-[9px] font-mono uppercase tracking-[0.3em]">Disponible</span>
            </div>
          </div>
        </div>

        <!-- Estado y links de compra -->
        <div class="space-y-4 flex-1 flex flex-col">
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-[#84d9d0] animate-ping" style="animation-duration: 1.5s;"></div>
            <span class="text-[#84d9d0] text-[10px] font-mono uppercase tracking-[0.5em]">Disponible ahora</span>
          </div>

          <!-- Logos de tiendas (PS5) -->
          <div class="pt-3 border-t border-[#84d9d0]/10">
            <span class="text-[#84d9d0]/30 text-[9px] font-mono uppercase tracking-[0.4em] block mb-4">Cómpralo en:</span>
            <div class="grid grid-cols-2 gap-3">
              <a
