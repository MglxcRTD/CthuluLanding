---
---
<section
  class="fifth-section relative py-24 md:py-44 px-6 md:px-16 overflow-hidden bg-transparent"
>
  <!-- Fondo atmosférico con efecto de abismo central -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-[-5%] left-[-10%] w-[50%] h-[60%] bg-[#84d9d0]/6 blur-[160px] rounded-full animate-glow-5a"></div>
    <div class="absolute top-[-5%] right-[-10%] w-[50%] h-[60%] bg-[#84d9d0]/6 blur-[160px] rounded-full animate-glow-5b"></div>
    <div class="absolute bottom-[0%] left-[25%] w-[50%] h-[50%] bg-[#02735e]/8 blur-[140px] rounded-full animate-glow-5c"></div>
    <!-- Patrón hexagonal tipo bioshock -->
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI2MCIgaGVpZ2h0PSI1MiI+PHBvbHlnb24gcG9pbnRzPSIzMCwxIDU5LDE2IDU5LDQ2IDMwLDYxIDEsNDYgMSwxNiIgZmlsbD0ibm9uZSIgc3Ryb2tlPSJyZ2JhKDEzMiwyMTcsMjA4LDAuOCkiIHN0cm9rZS13aWR0aD0iMC41Ii8+PC9zdmc+'); background-size: 60px 52px;"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_70%_at_50%_30%,transparent_20%,rgba(0,13,12,0.9)_100%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.04)_50%)] bg-[length:100%_4px] opacity-15"></div>
    <div class="absolute inset-0 opacity-[0.025] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10 flex flex-col items-center gap-12 md:gap-16">

    <!-- Encabezado -->
    <div class="text-center flex flex-col items-center gap-4">
      <div class="flex items-center gap-3">
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase leading-[0.88] text-white section-title-5">
        Un Mundo al<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#02735e] via-[#84d9d0] to-[#02735e] animate-shimmer-5">
          Borde del Fin
        </span>
      </h2>
      

    
      </div>
        <div class="flex items-center gap-4 opacity-60">
        <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#84d9d0]/60"></div>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <circle cx="6" cy="6" r="5" stroke="rgba(132,217,208,0.5)" stroke-width="1"/>
          <circle cx="6" cy="6" r="1.5" fill="rgba(132,217,208,0.5)"/>
        </svg>
        <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#84d9d0]/60"></div>
      </div>
    </div>

    <!-- Imagen centro con marco espectacular -->
    <div class="w-full max-w-4xl relative group">
      <!-- Halos exteriores -->
      <div class="absolute -inset-12 bg-[#84d9d0]/6 blur-[80px] rounded-full opacity-0 group-hover:opacity-100 transition-all duration-1500"></div>
      <div class="absolute -inset-6 bg-[#02735e]/8 blur-[50px] rounded-full opacity-60 group-hover:opacity-100 transition-all duration-1000"></div>

      <!-- Contenedor de imagen con marcos ornamentales -->
      <div class="relative overflow-hidden">
        <!-- Marco exterior decorativo -->
        <div class="absolute -top-3 -left-3 -right-3 -bottom-3 border border-[#84d9d0]/15 z-20 pointer-events-none"></div>
        <!-- Marco interior -->
        <div class="absolute top-2 left-2 right-2 bottom-2 border border-[#84d9d0]/10 z-20 pointer-events-none"></div>
        <!-- Esquinas grandes -->
        <div class="absolute top-0 left-0 w-16 h-16 border-t-2 border-l-2 border-[#84d9d0]/50 z-30"></div>
        <div class="absolute top-0 right-0 w-16 h-16 border-t-2 border-r-2 border-[#84d9d0]/50 z-30"></div>
        <div class="absolute bottom-0 left-0 w-16 h-16 border-b-2 border-l-2 border-[#84d9d0]/50 z-30"></div>
        <div class="absolute bottom-0 right-0 w-16 h-16 border-b-2 border-r-2 border-[#84d9d0]/50 z-30"></div>
        <!-- Marcadores centrales en los lados -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-8 h-[2px] bg-[#84d9d0]/30 z-30"></div>
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-8 h-[2px] bg-[#84d9d0]/30 z-30"></div>
        <div class="absolute left-0 top-1/2 -translate-y-1/2 w-[2px] h-8 bg-[#84d9d0]/30 z-30"></div>
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[2px] h-8 bg-[#84d9d0]/30 z-30"></div>

        <!-- Overlay atmosférico -->
        <div class="absolute inset-0 bg-gradient-to-b from-[#000d0c]/20 via-transparent to-[#000d0c]/50 z-10 pointer-events-none"></div>
        <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.05)_50%)] bg-[length:100%_3px] z-10 opacity-50 pointer-events-none"></div>
        <!-- Glow en hover -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-[radial-gradient(ellipse_at_center,rgba(132,217,208,0.06)_0%,transparent_70%)] z-10 transition-opacity duration-1000 pointer-events-none"></div>

        <img
          src="/Cthulhu/Screenshot_3.jpg"
          alt="El mundo de Cthulhu"
          class="w-full h-auto md:h-[500px] lg:h-[600px] object-cover object-center transition-all duration-[2000ms] group-hover:scale-103"
          style="filter: brightness(0.85) contrast(1.05);"
        />

        <!-- Barra superior HUD -->
        <div class="absolute top-0 left-0 right-0 bg-gradient-to-b from-[#000d0c]/70 to-transparent z-20 px-6 py-4 flex items-center justify-between">
          <span class="text-[#84d9d0]/40 text-[9px] font-mono uppercase tracking-[0.5em]">TRANSMISIÓN EN VIVO</span>
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-[#d91414] animate-ping opacity-60"></div>
            <span class="text-[#d91414]/60 text-[9px] font-mono uppercase tracking-[0.4em]">REC</span>
          </div>
          <span class="text-[#84d9d0]/40 text-[9px] font-mono uppercase tracking-[0.5em]">47°9'S 126°43'W</span>
        </div>
      </div>
    </div>

    <!-- Texto debajo -->
    <div class="text-center flex flex-col items-center gap-6 max-w-3xl">

      <p class="text-[#84d9d0]/65 text-lg md:text-xl font-light leading-relaxed">
        Contempla paisajes que ninguna mente humana ha concebido. Las profundidades del Pacífico ocultan verdades que <span class="text-[#84d9d0] font-medium">redefinen todo lo que creías saber</span> sobre el universo y el lugar de la humanidad en él.
      </p>

  </div>

  <!-- Botón Compra Ya -->
  <div class="relative z-10 flex justify-center mt-20 md:mt-28">
    <a href="#comprar" class="buy-btn group relative">
      <div class="absolute -inset-[1px] bg-gradient-to-r from-[#84d9d0]/0 via-[#84d9d0]/40 to-[#84d9d0]/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="relative border border-[#84d9d0]/30 bg-[#000d0c]/80 backdrop-blur-sm px-12 py-4 group-hover:border-[#84d9d0]/60 transition-all duration-500 overflow-hidden">
        <div class="absolute inset-0 bg-[#84d9d0]/0 group-hover:bg-[#84d9d0]/5 transition-all duration-500"></div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-[linear-gradient(transparent_50%,rgba(132,217,208,0.05)_50%)] bg-[length:100%_3px] animate-interference"></div>
        <span class="relative z-10 text-[#84d9d0]/60 group-hover:text-[#84d9d0] text-xs uppercase tracking-[0.5em] font-serif transition-all duration-300">
          ◈ Compra Ya ◈
        </span>
      </div>
    </a>
  </div>
</section>

<style>
  .section-title-5 {
    font-family: 'Georgia', 'Times New Roman', serif;
    text-shadow: 0 0 80px rgba(132, 217, 208, 0.12);
  }

  @keyframes glow-5 {
    0%, 100% { opacity: 0.06; transform: scale(1); }
    50% { opacity: 0.14; transform: scale(1.1); }
  }
  .animate-glow-5a { animation: glow-5 14s ease-in-out infinite; }
  .animate-glow-5b { animation: glow-5 18s ease-in-out infinite 5s; }
  .animate-glow-5c { animation: glow-5 11s ease-in-out infinite 2s; }

  @keyframes shimmer-5 {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  .animate-shimmer-5 {
    background-size: 200% auto;
    animation: shimmer-5 8s linear infinite;
  }

  @keyframes interference {
    0% { background-position: 0 0; }
    100% { background-position: 0 100%; }
  }
  .animate-interference { animation: interference 0.3s infinite linear; }
</style>