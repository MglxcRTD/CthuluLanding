---
---
<section
  class="sixth-section relative py-24 md:py-44 px-6 md:px-16 overflow-hidden bg-transparent"
>
  <!-- Fondo atmosférico -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-[10%] left-[20%] w-[60%] h-[40%] bg-[#84d9d0]/6 blur-[160px] rounded-full animate-breathe-6a"></div>
    <div class="absolute bottom-[10%] left-[20%] w-[60%] h-[40%] bg-[#d91414]/6 blur-[160px] rounded-full animate-breathe-6b"></div>
    <!-- Línea central vertical -->
    <div class="absolute left-1/2 top-[10%] bottom-[10%] w-[1px] bg-gradient-to-b from-transparent via-[#84d9d0]/15 to-transparent"></div>
    <!-- Línea central horizontal -->
    <div class="absolute top-1/2 left-[5%] right-[5%] h-[1px] bg-gradient-to-r from-transparent via-[#84d9d0]/10 to-transparent"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_20%,rgba(0,13,12,0.8)_100%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.03)_50%)] bg-[length:100%_4px] opacity-15"></div>
    <div class="absolute inset-0 opacity-[0.02] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">

    <!-- Header -->
    <div class="text-center mb-16 md:mb-20 flex flex-col items-center gap-4">
      <div class="flex items-center gap-3">
      </div>
      <h2 class="text-4xl md:text-6xl font-black uppercase text-white section-title-6">
        El <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#84d9d0] to-[#02735e]">Gran Despertar</span>
      </h2>
    </div>

    <!-- Grid 2x2 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">

      <!-- [1] ARRIBA IZQUIERDA: Imagen -->
      <div class="group relative order-1">
        <div class="absolute -inset-4 bg-[#02735e]/6 blur-[50px] opacity-0 group-hover:opacity-100 transition-all duration-1000"></div>
        <div class="relative overflow-hidden">
          <div class="absolute top-0 left-0 w-10 h-10 border-t border-l border-[#84d9d0]/50 z-20"></div>
          <div class="absolute top-0 right-0 w-10 h-10 border-t border-r border-[#84d9d0]/50 z-20"></div>
          <div class="absolute bottom-0 left-0 w-10 h-10 border-b border-l border-[#84d9d0]/50 z-20"></div>
          <div class="absolute bottom-0 right-0 w-10 h-10 border-b border-r border-[#84d9d0]/50 z-20"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-transparent to-[#000d0c]/50 z-10 pointer-events-none"></div>
          <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.06)_50%)] bg-[length:100%_3px] z-10 opacity-35 pointer-events-none"></div>
          <img
            src="/Cthulhu/Screenshot_1 (1).jpg"
            alt="Los cultistas de Cthulhu"
            class="w-full h-64 md:h-80 object-cover transition-all duration-[1400ms] group-hover:scale-105 group-hover:brightness-110"
          />
        </div>
      </div>

      <!-- [2] ARRIBA DERECHA: Texto -->
      <div class="flex flex-col justify-center space-y-6 order-2 md:pl-4">
        <div class="flex items-center gap-3">

        </div>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-black uppercase leading-[0.9] text-white card-title-6">
          Los Heraldos<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#84d9d0] to-[#02735e]">del Antiguo</span>
        </h3>
        <div class="w-16 h-[1px] bg-gradient-to-r from-[#84d9d0]/50 to-transparent"></div>
        <p class="text-[#84d9d0]/65 text-base md:text-lg font-light leading-relaxed">
          Sectas de adoradores han esperado durante generaciones el regreso de su dios. Sus rituales, sus lenguas muertas, sus geometrías sagradas...
          <span class="text-[#84d9d0]/85 font-medium"> todo converge en este momento.</span>
        </p>
        <p class="text-[#84d9d0]/40 text-sm font-light italic">
          ¿Eres un observador o ya formas parte del culto?
        </p>
      </div>

      <!-- [3] ABAJO IZQUIERDA: Texto -->
      <div class="flex flex-col justify-center space-y-6 order-4 md:order-3 md:pr-4">
        <div class="flex items-center gap-3">
        </div>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-black uppercase leading-[0.9] text-white card-title-6">
          La Verdad<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#d91414] to-[#84d9d0]">Prohibida</span>
        </h3>
        <div class="w-16 h-[1px] bg-gradient-to-r from-[#d91414]/50 to-transparent"></div>
        <p class="text-[#84d9d0]/65 text-base md:text-lg font-light leading-relaxed">
          El Necronomicón no es leyenda. Lo que encontrarás en las profundidades pondrá a prueba no solo tu valentía,
          sino <span class="text-[#d91414]/80 font-medium">los límites mismos de la realidad.</span>
        </p>
        <div class="flex items-center gap-3 pt-2">
          <div class="w-2 h-2 bg-[#d91414]/60 animate-ping-slow"></div>
          <span class="text-[#d91414]/50 text-[9px] font-mono uppercase tracking-[0.4em]">NIVEL DE AMENAZA: MÁXIMO</span>
        </div>
      </div>

      <!-- [4] ABAJO DERECHA: Imagen -->
      <div class="group relative order-3 md:order-4">
        <div class="absolute -inset-4 bg-[#d91414]/6 blur-[50px] opacity-0 group-hover:opacity-100 transition-all duration-1000"></div>
        <div class="relative overflow-hidden">
          <div class="absolute top-0 left-0 w-10 h-10 border-t border-l border-[#d91414]/40 z-20"></div>
          <div class="absolute top-0 right-0 w-10 h-10 border-t border-r border-[#d91414]/40 z-20"></div>
          <div class="absolute bottom-0 left-0 w-10 h-10 border-b border-l border-[#d91414]/40 z-20"></div>
          <div class="absolute bottom-0 right-0 w-10 h-10 border-b border-r border-[#d91414]/40 z-20"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-transparent to-[#000d0c]/50 z-10 pointer-events-none"></div>
          <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,13,12,0.06)_50%)] bg-[length:100%_3px] z-10 opacity-35 pointer-events-none"></div>
          <!-- HUD inferior -->

          <img
            src="/Cthulhu/Screenshot_2 (1).jpg"
            alt="El despertar de Cthulhu"
            class="w-full h-64 md:h-80 object-cover transition-all duration-[1400ms] group-hover:scale-105 group-hover:brightness-110"
          />
        </div>
      </div>

    </div>
  </div>

  <!-- Botón Compra Ya -->
  <div class="relative z-10 flex justify-center mt-20 md:mt-28">
    <a href="#comprar" class="buy-btn group relative">
      <div class="absolute -inset-[1px] bg-gradient-to-r from-[#84d9d0]/0 via-[#84d9d0]/40 to-[#84d9d0]/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="relative border border-[#84d9d0]/30 bg-[#000d0c]/80 backdrop-blur-sm px-12 py-4 group-hover:border-[#84d9d0]/60 transition-all duration-500 overflow-hidden">
        <div class="absolute inset-0 bg-[#84d9d0]/0 group-hover:bg-[#84d9d0]/5 transition-all duration-500"></div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-[linear-gradient(transparent_50%,rgba(132,217,208,0.05)_50%)] bg-[length:100%_3px] animate-interference"></div>
        <span class="relative z-10 text-[#84d9d0]/60 group-hover:text-[#84d9d0] text-xs uppercase tracking-[0.5em] font-serif transition-all duration-300">
          ◈ Compra Ya ◈
        </span>
      </div>
    </a>
  </div>
</section>

<style>
  .section-title-6, .card-title-6 {
    font-family: 'Georgia', 'Times New Roman', serif;
  }

  @keyframes breathe-6 {
    0%, 100% { opacity: 0.06; transform: scale(1); }
    50% { opacity: 0.14; transform: scale(1.08); }
  }
  .animate-breathe-6a { animation: breathe-6 15s ease-in-out infinite; }
  .animate-breathe-6b { animation: breathe-6 19s ease-in-out infinite 6s; }

  @keyframes ping-slow {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.8); opacity: 0; }
  }
  .animate-ping-slow { animation: ping-slow 2s ease-in-out infinite; }

  @keyframes interference {
    0% { background-position: 0 0; }
    100% { background-position: 0 100%; }
  }
  .animate-interference { animation: interference 0.3s infinite linear; }
</style>